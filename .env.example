# BillFlow front-end environment.
# Only VITE_-prefixed vars reach the client. NEVER put secrets here (CLAUDE.md §16.5).
# Copy to .env.development / .env.production and adjust. All vars are validated by src/config at startup.

# App
VITE_APP_NAME=BillFlow
VITE_APP_ENV=development            # development | staging | production

# API transport (RTK Query over Axios). In dev this is proxied (see vite.config.ts).
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT_MS=30000

# Logging (CLAUDE.md §15)
VITE_LOG_LEVEL=debug                # debug | info | warn | error | silent
VITE_LOG_REMOTE_URL=                # optional remote sink (Sentry/Datadog/custom); empty = console only

# Audit (CLAUDE.md §16.3)
VITE_AUDIT_ENDPOINT=/api/audit

# Feature flags (CLAUDE.md §16.4) — static config now; SaaS provider later
VITE_FEATURE_FLAGS_URL=

# i18n / locale (CLAUDE.md §16.6)
VITE_DEFAULT_LOCALE=en-IN
VITE_DEFAULT_CURRENCY=INR

# Multi-tenant — tenant resolved from auth claim; this is only a dev fallback (CLAUDE.md §11)
VITE_DEFAULT_TENANT_ID=

# Dev tooling
VITE_ENABLE_MSW=true                # mock API with MSW in dev
